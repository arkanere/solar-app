{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "solar-app-main-app": {
      "packageName": "main-app",
      "development": {
        "fallback": "solarvipani.com",
        "local": 7123
      }
    },
    "solar-app-au": {
      "packageName": "au-app",
      "routing": [
        {
          "paths": ["/au", "/au/:path*"]
        }
      ],
      "development": {
        "local": 7124
      }
    },
    "solar-app-us": {
      "packageName": "us-app",
      "routing": [
        {
          "paths": ["/us", "/us/:path*"]
        }
      ],
      "development": {
        "local": 7125
      }
    }
  }
}