{
	"name": "main-app",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "VC_MICROFRONTENDS_CONFIG=./microfrontends.json vite dev --port $(microfrontends port)",
		"proxy": "microfrontends proxy ./microfrontends.json --local-apps solar-app-main-app solar-app-au solar-app-us",
		"build": "vite build",
		"preview": "vite preview",
		"clean": "rm -rf .svelte-kit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"devDependencies": {
		"@eslint/js": "^9.29.0",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"eslint": "^9.29.0",
		"eslint-plugin-svelte": "^3.9.2",
		"globals": "^16.2.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"svelte-cloudinary": "^2.3.0",
		"typescript": "^5.0.0",
		"vite": "^5.0.3"
	},
	"type": "module",
	"dependencies": {
		"@auth/sveltekit": "^1.7.4",
		"@langchain/core": "^0.3.57",
		"@langchain/openai": "^0.5.11",
		"@langchain/pinecone": "^0.2.0",
		"@pinecone-database/pinecone": "^5.1.2",
		"@sendgrid/mail": "^8.1.3",
		"@sveltejs/adapter-vercel": "^5.4.4",
		"@vercel/microfrontends": "^2.0.0",
		"@vercel/postgres": "^0.9.0",
		"@vercel/speed-insights": "^1.2.0",
		"bcrypt": "^5.1.1",
		"cloudinary": "^2.6.0",
		"csv-parser": "^3.2.0",
		"dotenv": "^16.4.5",
		"langchain": "^0.3.27",
		"openai": "^4.78.1",
		"puppeteer": "^24.17.0",
		"twilio": "^5.3.1",
		"uuid": "^11.0.5"
	}
}
