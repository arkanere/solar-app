{
	"name": "main-app",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "VC_MICROFRONTENDS_CONFIG=./microfrontends.json vite dev --port $(microfrontends port)",
		"proxy": "microfrontends proxy ./microfrontends.json --local-apps solar-app-main-app solar-app-au solar-app-us",
		"build": "vite build",
		"preview": "vite preview",
		"clean": "rm -rf .svelte-kit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"type": "module",
	"dependencies": {
		"@vercel/microfrontends": "^2.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.2.0",
		"@sveltejs/kit": "^2.49.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/bcrypt": "^6.0.0",
		"@types/uuid": "^10.0.0",
		"svelte": "^5.46.1"
	}
}
