{
	"name": "main-app",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "VC_MICROFRONTENDS_CONFIG=./microfrontends.json vite dev --port $(microfrontends port)",
		"proxy": "microfrontends proxy ./microfrontends.json --local-apps solar-app-main-app solar-app-au solar-app-us",
		"build": "vite build",
		"preview": "vite preview",
		"clean": "rm -rf .svelte-kit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"type": "module",
	"dependencies": {
		"@langchain/core": "^0.3.80",
		"@langchain/openai": "^0.5.18",
		"@langchain/pinecone": "^0.2.0",
		"@pinecone-database/pinecone": "^5.1.2",
		"@radix-ui/react-slider": "^1.3.6",
		"@vercel/microfrontends": "^2.0.0",
		"@vercel/postgres": "^0.10.0",
		"bcryptjs": "^3.0.2",
		"bits-ui": "^2.15.4",
		"cloudinary": "^2.6.0",
		"clsx": "^2.1.1",
		"jspdf": "^3.0.4",
		"langchain": "^0.3.37",
		"markdown-it": "^14.1.0",
		"posthog-js": "^1.373.4",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss-animate": "^1.0.7",
		"uuid": "^11.0.5"
	},
	"devDependencies": {
		"@internationalized/date": "^3.10.1",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-vercel": "^6.2.0",
		"@sveltejs/kit": "^2.49.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/uuid": "^10.0.0",
		"autoprefixer": "^10.4.23",
		"formsnap": "^2.0.1",
		"mode-watcher": "^1.1.0",
		"postcss": "^8.5.6",
		"svelte": "^5.46.1",
		"sveltekit-superforms": "^2.29.1",
		"tailwindcss": "^4.1.18",
		"utf-8-validate": "^6.0.0"
	}
}
