{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "sveltekit",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/in",
      "destination": "https://solar-app-in.vercel.app/"
    },
    {
      "source": "/in/:path*",
      "destination": "https://solar-app-in.vercel.app/:path*"
    },
    {
      "source": "/us",
      "destination": "https://solar-app-us.vercel.app/"
    },
    {
      "source": "/us/:path*",
      "destination": "https://solar-app-us.vercel.app/:path*"
    },
    {
      "source": "/uk",
      "destination": "https://solar-app-uk.vercel.app/"
    },
    {
      "source": "/uk/:path*",
      "destination": "https://solar-app-uk.vercel.app/:path*"
    },
    {
      "source": "/au",
      "destination": "https://solar-app-au.vercel.app/"
    },
    {
      "source": "/au/:path*",
      "destination": "https://solar-app-au.vercel.app/:path*"
    },
  ]
}