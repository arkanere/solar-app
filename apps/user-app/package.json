		"@tailwindcss/postcss": "^4.1.18",
		"@types/uuid": "^10.0.0",
		"autoprefixer": "^10.4.23",
		"postcss": "^8.5.6",
		"svelte": "^5.46.1",
		"svelte-check": "^3.6.0",
		"tailwindcss": "^4.1.18",
