{
  "name": "solar-app-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:main": "npm run dev -w main-app",
    "dev:admin": "npm run dev -w solarvipani-admin",
    "dev:business": "npm run dev -w solarvipani-business",
    "dev:in": "npm run dev -w in-app",
    "dev:uk": "npm run dev -w uk-app",
    "dev:us": "npm run dev -w us-app",
    "dev:au": "npm run dev -w au-app",
    "dev:user": "npm run dev -w user-app",
    "dev:uk-next": "npm run dev -w uk-app-nextjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "eslint": "^9.29.0",
    "eslint-plugin-svelte": "^3.9.2",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^4.2.7",
    "svelte-check": "^3.6.0",
    "svelte-cloudinary": "^2.3.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.3"
  },
  "dependencies": {
    "@auth/sveltekit": "^1.7.4",
    "@langchain/core": "^0.3.57",
    "@langchain/openai": "^0.5.11",
    "@langchain/pinecone": "^0.2.0",
    "@pinecone-database/pinecone": "^5.1.2",
    "@sendgrid/mail": "^8.1.3",
    "@sveltejs/adapter-vercel": "^5.4.4",
    "@vercel/postgres": "^0.10.0",
    "@vercel/speed-insights": "^1.2.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.6.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.5",
    "langchain": "^0.3.27",
    "openai": "^4.78.1",
    "puppeteer": "^24.17.0",
    "twilio": "^5.3.1",
    "uuid": "^11.0.5"
  },
  "packageManager": "npm@10.0.0"
}
