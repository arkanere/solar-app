{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "sveltekit",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/in",
      "destination": "https://solar-app-in.vercel.app/"
    },
    {
      "source": "/in/:path*",
      "destination": "https://solar-app-in.vercel.app/:path*"
    }
  ]
}